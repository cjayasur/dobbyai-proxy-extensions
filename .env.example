# Copy to .env (gitignored). These are the vars MY extensions add.
# The upstream 1rgs/claude-code-proxy has its own additional env — see its README.

# SQLite store of SHA-256-hashed dk_* API keys (auth_middleware.py).
# Create your own DB with an `api_keys` table; never commit the .db file.
DOBBYAI_DB_PATH=./dobbyai.db

# Local vision-language model endpoint (vision routing in server.extensions.patch).
# Point at your own self-hosted VL model — nothing external.
VISION_MODEL_BASE=http://your-vision-host:8005/v1
