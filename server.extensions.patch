+async def describe_image_with_vl(image_source: Dict[str, Any]) -> str:
+    """Send an image to the VL model and get a text description.
+    Used in the two-stage VL→Coder pipeline: VL describes, Coder codes."""
+    if not VISION_MODEL_BASE or not VISION_MODEL:
+        return "[Image: vision model not configured — set VISION_MODEL_BASE and VISION_MODEL]"
+
+    # Build OpenAI vision message with the image
+    image_content = {
+        "type": "image_url",
+        "image_url": {}
+    }
+    # Anthropic sends base64 as {type: "base64", media_type: "image/png", data: "..."}
+    if image_source.get("type") == "base64":
+        media_type = image_source.get("media_type", "image/png")
+        data = image_source.get("data", "")
+        image_content["image_url"]["url"] = f"data:{media_type};base64,{data}"
+    elif image_source.get("type") == "url":
+        image_content["image_url"]["url"] = image_source.get("url", "")
+    else:
+        return f"[Image: unsupported source type {image_source.get('type')}]"
+
+    try:
+        async with httpx.AsyncClient(timeout=120.0) as client:
+            resp = await client.post(
+                f"{VISION_MODEL_BASE}/chat/completions",
+                json={
+                    "model": VISION_MODEL,
+                    "messages": [
+                        {
+                            "role": "user",
+                            "content": [
+                                {"type": "text", "text": "Describe this image in detail. Include all text, UI elements, layout, and any code or terminal output visible."},
+                                image_content
+                            ]
+                        }
+                    ],
+                    "max_tokens": 1024,
+                    "temperature": 0.1
+                }
+            )
+            resp.raise_for_status()
+            result = resp.json()
+            description = result["choices"][0]["message"]["content"]
+            logger.warning(f"🖼️ VL described image ({len(description)} chars)")
+            return f"[Image description from Qwen3-VL:\n{description}\n]"
+    except Exception as e:
+        logger.error(f"VL image description failed: {e}")
+        return f"[Image: VL model error — {str(e)[:200]}]"
+
+
+async def _process_image_block(block) -> str:
+    """Extract image source from a block and get VL description."""
+    source = block.source if hasattr(block, 'source') else {}
+    if isinstance(source, dict):
+        return await describe_image_with_vl(source)
+    else:
+        return await describe_image_with_vl(dict(source) if hasattr(source, '__iter__') else {})
+
+
+async def replace_images_with_descriptions(messages: list) -> list:
+    """Scan Anthropic messages for image blocks, replace with VL descriptions.
+    Checks both top-level content AND nested tool_result content blocks.
+    This enables the text-only Coder model to understand image content."""
+    if not VISION_MODEL_BASE:
+        return messages
+
+    import copy
+    messages = copy.deepcopy(messages)
+
+    for msg in messages:
+        if not hasattr(msg, 'content') or isinstance(msg.content, str):
+            continue
+        new_content = []
+        for block in msg.content:
+            if hasattr(block, 'type') and block.type == "image":
+                # Top-level image block (direct user message with image)
+                description = await _process_image_block(block)
+                text_block = type('TextBlock', (), {'type': 'text', 'text': description})()
+                new_content.append(text_block)
+            elif hasattr(block, 'type') and block.type == "tool_result":
+                # Tool result may contain nested image blocks (e.g. Read tool returning an image)
+                if hasattr(block, 'content') and isinstance(block.content, list):
+                    new_sub = []
+                    for sub in block.content:
+                        if hasattr(sub, 'type') and sub.type == "image":
+                            description = await _process_image_block(sub)
+                            text_sub = type('TextBlock', (), {'type': 'text', 'text': description})()
+                            new_sub.append(text_sub)
+                        elif isinstance(sub, dict) and sub.get('type') == 'image':
+                            source = sub.get('source', {})
+                            description = await describe_image_with_vl(source)
+                            new_sub.append({'type': 'text', 'text': description})
+                        else:
+                            new_sub.append(sub)
+                    block.content = new_sub
+                new_content.append(block)
+            else:
+                new_content.append(block)
+        msg.content = new_content
+
+    return messages
 
